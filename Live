<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>بث مباشر | isaad Live</title>
    <!-- خط Cairo العربي -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&display=swap" rel="stylesheet">
    <!-- مكتبة الأيقونات -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        :root {
            --accent-color: #f1c40f; /* الذهبي */
            --bg-dark: #0a0a0a;
            --panel-bg: #161616;
            --text-main: #ffffff;
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        
        body {
            margin: 0;
            background-color: var(--bg-dark);
            color: var(--text-main);
            font-family: 'Cairo', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
        }

        header {
            width: 100%;
            background: var(--panel-bg);
            padding: 15px;
            text-align: center;
            border-bottom: 2px solid var(--accent-color);
            box-shadow: 0 4px 10px rgba(0,0,0,0.5);
        }

        header h1 {
            margin: 0;
            font-size: 22px;
            color: var(--accent-color);
            text-transform: uppercase;
        }

        .main-container {
            width: 100%;
            max-width: 900px;
            margin-top: 20px;
            padding: 0 10px;
        }

        /* حاوية الـ iframe اللي اشتغلت معاك */
        .player-card {
            background: #000;
            border-radius: 15px;
            overflow: hidden;
            position: relative;
            aspect-ratio: 16 / 9;
            box-shadow: 0 0 20px rgba(241, 196, 15, 0.2);
            border: 1px solid #333;
        }

        iframe {
            width: 100%;
            height: 100%;
            border: none;
        }

        .stream-details {
            margin-top: 20px;
            background: var(--panel-bg);
            padding: 20px;
            border-radius: 15px;
            text-align: center;
        }

        .stream-title {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 15px;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
        }

        .live-label {
            background: #e74c3c;
            color: white;
            padding: 2px 10px;
            border-radius: 5px;
            font-size: 11px;
            animation: pulse 1.5s infinite;
        }

        /* قائمة المباريات */
        .channel-buttons {
            display: grid;
            grid-template-columns: 1fr;
            gap: 12px;
            margin-top: 10px;
        }

        .btn-ch {
            padding: 15px;
            border-radius: 12px;
            border: 1px solid #333;
            background: #222;
            color: white;
            cursor: pointer;
            font-family: 'Cairo';
            font-weight: bold;
            transition: 0.3s;
            font-size: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .btn-ch.active {
            background: var(--accent-color);
            color: #000;
            border-color: var(--accent-color);
        }

        @keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.5; }
            100% { opacity: 1; }
        }

        footer { padding: 30px; color: #444; font-size: 12px; text-align: center; }
    </style>
</head>
<body>

    <header>
        <h1>ISAAD LIVE</h1>
    </header>

    <div class="main-container">
        <!-- منطقة الـ Iframe الموحدة -->
        <div class="player-card">
            <iframe 
                id="livePlayer"
                src="https://majed-koora.co/stream.php?channel=chche93&file=stream.m3u8" 
                allowfullscreen="true" 
                scrolling="no">
            </iframe>
        </div>

        <div class="stream-details">
            <div class="stream-title">
                <span class="live-label">بث مباشر</span>
                <span id="chName">المكسيك ضد التشيك</span>
            </div>

            <!-- الأزرار -->
            <div class="channel-buttons">
                <!-- مباراة 1 -->
                <button class="btn-ch active" onclick="changeCh('https://majed-koora.co/stream.php?channel=chche93&file=stream.m3u8', 'المكسيك ضد التشيك', this)">
                    <span>المكسيك ضد التشيك</span>
                    <i class="fas fa-play-circle"></i>
                </button>
                
                <!-- مباراة 2 (نفس طريقة المكسيك بالظبط) -->
                <button class="btn-ch" onclick="changeCh('https://3.bb1.dpdns.org/hls/0/stream.m3u8', 'كوريا ضد جنوب افريقيا', this)">
                    <span>كوريا ضد جنوب افريقيا</span>
                    <i class="fas fa-play-circle"></i>
                </button>
            </div>
        </div>
    </div>

    <footer>جميع الحقوق محفوظة © 2026 لـ isaad Live</footer>

    <script>
        function changeCh(url, name, btn) {
            // تحديث رابط الـ Iframe فقط
            document.getElementById('livePlayer').src = url;
            // تحديث الاسم
            document.getElementById('chName').innerText = name;
            // تحديث الأزرار
            document.querySelectorAll('.btn-ch').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    </script>

</body>
</html>
