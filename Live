<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Isaad Matches - إسعاد ماتش</title>
    
    <!-- Video.js CSS -->
    <link href="https://vjs.zencdn.net/7.20.3/video-js.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Cairo', sans-serif;
            background-color: #0f0f0f;
            color: white;
            margin: 0;
            padding: 0;
        }

        /* Header */
        header {
            background-color: #1a1a1a;
            padding: 20px;
            text-align: center;
            border-bottom: 2px solid #00ff88;
            box-shadow: 0 4px 10px rgba(0,0,0,0.5);
        }

        header h1 {
            margin: 0;
            color: #00ff88;
            font-size: 28px;
            text-transform: uppercase;
        }

        /* Main Container */
        .container {
            max-width: 1000px;
            margin: 20px auto;
            padding: 10px;
        }

        /* Video Player Wrapper */
        .video-container {
            position: relative;
            background: #000;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 0 20px rgba(0,255,136,0.2);
            margin-bottom: 30px;
        }

        .video-js {
            width: 100% !important;
            height: auto;
            aspect-ratio: 16 / 9;
        }

        /* Channel List Area */
        .channel-list-title {
            font-size: 20px;
            margin-bottom: 15px;
            border-right: 4px solid #00ff88;
            padding-right: 10px;
        }

        .channels-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 15px;
        }

        .channel-card {
            background: #1a1a1a;
            border: 1px solid #333;
            border-radius: 8px;
            padding: 15px;
            text-align: center;
            cursor: pointer;
            transition: 0.3s;
        }

        .channel-card:hover {
            background: #00ff88;
            color: #000;
            transform: translateY(-5px);
        }

        .channel-card.active {
            border-color: #00ff88;
            background: rgba(0, 255, 136, 0.1);
            color: #00ff88;
        }

        .channel-card i {
            display: block;
            margin-bottom: 10px;
            font-size: 24px;
        }

        footer {
            text-align: center;
            padding: 20px;
            font-size: 14px;
            color: #777;
        }

        /* Status Indicator */
        .live-dot {
            height: 10px;
            width: 10px;
            background-color: #ff0000;
            border-radius: 50%;
            display: inline-block;
            margin-left: 5px;
            animation: blink 1s infinite;
        }

        @keyframes blink {
            0% { opacity: 1; }
            50% { opacity: 0.3; }
            100% { opacity: 1; }
        }
    </style>
</head>
<body>

    <header>
        <h1>Isaad Matches</h1>
    </header>

    <div class="container">
        
        <!-- Player Section -->
        <div class="video-container">
            <video id="main-player" class="video-js vjs-big-play-centered vjs-theme-city" controls preload="auto" width="640" height="264">
                <p class="vjs-no-js">
                    لتشغيل الفيديو، يرجى تفعيل جافا سكريبت أو استخدام متصفح يدعم HTML5.
                </p>
            </video>
        </div>

        <!-- Channels Section -->
        <div class="channel-list-title">
            <span class="live-dot"></span> قائمة القنوات المباشرة
        </div>

        <div class="channels-grid">
            <!-- Channel 1 -->
            <div class="channel-card" onclick="playChannel('https://table.houseinventer.com/pdf/AzMjD2IyADQPb2tLfQ/index.m3u8', this)">
                <strong>Isaad Max 1</strong>
            </div>

            <!-- Channel 2 -->
            <div class="channel-card" onclick="playChannel('http://185.202.236.109/bein/tracks-v1a1/mono.ts.m3u8', this)">
                <strong>Isaad Max 2</strong>
            </div>
            
            <!-- يمكنك إضافة المزيد من القنوات هنا بنفس الطريقة -->
        </div>

    </div>

    <footer>
        &copy; 2024 جميع الحقوق محفوظة لـ Isaad Matches
    </footer>

    <!-- Video.js Scripts -->
    <script src="https://vjs.zencdn.net/7.20.3/video.min.js"></script>
    
    <script>
        // تهيئة المشغل
        var player = videojs('main-player');

        // وظيفة تغيير القناة
        function playChannel(url, element) {
            // تغيير رابط الفيديو
            player.src({
                src: url,
                type: 'application/x-mpegURL'
            });

            // تشغيل الفيديو تلقائياً
            player.play();

            // تحديث الشكل (Active Class)
            const cards = document.querySelectorAll('.channel-card');
            cards.forEach(card => card.classList.remove('active'));
            element.classList.add('active');

            // التمرير للاعلى لمشاهدة الفيديو (اختياري)
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // تشغيل القناة الأولى تلقائياً عند فتح الموقع
        window.onload = function() {
            const firstChannel = document.querySelector('.channel-card');
            playChannel('http://185.202.236.109/Beinsport01001/tracks-v1a1/mono.ts.m3u8', firstChannel);
        };
    </script>
</body>
</html>
